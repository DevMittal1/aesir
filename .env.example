# Verification token configured in Meta App Dashboard for webhook subscription
INSTAGRAM_VERIFY_TOKEN=your_verify_token_here

# Meta App Secret used to compute HMAC SHA-256 for X-Hub-Signature-256 header validation
INSTAGRAM_APP_SECRET=your_app_secret_here

# Meta App ID used for initiating Facebook OAuth flows (SaaS login)
INSTAGRAM_APP_ID=your_app_id_here

# Meta Graph API version to use (e.g. v20.0)
INSTAGRAM_API_VERSION=v20.0

# Optional settings for running local dev server
HOST=0.0.0.0
PORT=8000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=instagram_webhook_db

# Rate Limiting Configuration
RATE_LIMIT_CALLS=60
RATE_LIMIT_PERIOD_SECONDS=60

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=instagram-webhook-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

BACKEND_PUBLIC_URL = http://localhost:8000
FRONTEND_DASHBOARD_URL=https://insta-ai-frontend.vercel.app/dashboard
OAUTH_REDIRECT_URI=
INSTAGRAM_OAUTH_BASE_URL=https://api.instagram.com/oauth/authorize
FACEBOOK_OAUTH_BASE_URL=https://www.facebook.com
GRAPH_API_BASE_URL=https://graph.facebook.com
